{
  "private": true,
  "name": "web3",
  "description": "My collection of web3 exercises, all in one place, well separated",
  "license": "MIT",
  "sideEffects": false,
  "main": "dist/worker.js",
  "engines": {
    "node": ">=14"
  },
  "scripts": {
    "start": "remix-serve build",
    "commit": "npx cz",
    "deploy": "fly deploy --remote-only",
    "reinstall": "rm -rf node_modules package-lock.json && npm i",
    "postinstall": "remix setup node",
    "build": "npm run build:css && NODE_ENV=production npm run build:app",
    "build:css": "postcss styles --base styles --dir app/styles --env production",
    "build:app": "remix build",
    "dev": "pm2-dev pm2.config.js",
    "dev:css": "postcss styles --base styles --dir app/styles -w",
    "dev:app": "remix dev",
    "hardhat:node": "hardhat node",
    "hardhat:compile": "hardhat compile",
    "hardhat:mint:deploy": "hardhat run scripts/mint/deploy.ts --network rinkeby",
    "hardhat:waver:run": "hardhat run scripts/wave/run.ts",
    "hardhat:waver:deploy": "hardhat run scripts/wave/deploy.ts --network rinkeby",
    "hardhat:greeter:run": "hardhat run scripts/greeter/run.ts",
    "hardhat:greeter:deploy": "hardhat run scripts/greeter/deploy.ts --network rinkeby"
  },
  "dependencies": {
    "@prisma/client": "^3.12.0",
    "@remix-run/react": "^1.3.4",
    "@remix-run/serve": "^1.3.4",
    "clsx": "^1.1.1",
    "ethers": "^5.6.2",
    "ipfs": "^0.62.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "remix": "^1.3.4",
    "tiny-invariant": "^1.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^16.2.3",
    "@commitlint/config-conventional": "^16.2.1",
    "@nomiclabs/hardhat-ethers": "^2.0.5",
    "@nomiclabs/hardhat-etherscan": "^3.0.3",
    "@nomiclabs/hardhat-waffle": "^2.0.3",
    "@openzeppelin/contracts": "^4.5.0",
    "@remix-run/dev": "^1.3.4",
    "@typechain/ethers-v5": "^10.0.0",
    "@typechain/hardhat": "^6.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.1.0",
    "@types/node": "^17.0.23",
    "@types/react": "^17.0.43",
    "@types/react-dom": "^17.0.14",
    "@typescript-eslint/eslint-plugin": "^5.18.0",
    "@typescript-eslint/parser": "^5.18.0",
    "chai": "^4.3.6",
    "commitizen": "^4.2.4",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^16.0.0",
    "esbuild": "0.14.32",
    "eslint": "^8.12.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.29.4",
    "eslint-plugin-react-hooks": "^4.4.0",
    "ethereum-waffle": "^3.4.4",
    "hardhat": "^2.9.3",
    "hardhat-gas-reporter": "^1.0.8",
    "miniflare": "2.4.0",
    "pm2": "^5.2.0",
    "postcss": "^8.4.12",
    "postcss-cli": "^9.1.0",
    "postcss-import": "^14.1.0",
    "prettier": "^2.6.2",
    "prettier-plugin-solidity": "1.0.0-beta.19",
    "prisma": "^3.12.0",
    "solhint": "^3.3.7",
    "solidity-coverage": "^0.7.20",
    "tailwindcss": "^3.0.23",
    "ts-node": "^10.7.0",
    "typechain": "^8.0.0",
    "typescript": "^4.6.3"
  }
}
